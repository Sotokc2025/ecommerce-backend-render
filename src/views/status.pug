doctype html
html(lang="es")
  head
    meta(charset="UTF-8")
    meta(name="viewport" content="width=device-width, initial-scale=1.0")
    title TyMCO Legacy BackEnd Server - Status Dashboard
    style.
      @import url('https://fonts.googleapis.com/css2?family=Creepster&family=Roboto:wght@300;400;700&display=swap');
      
      :root {
        --bg-color: #0d1117;
        --text-color: #c9d1d9;
        --accent-glow: #58a6ff;
        --lightning: #1f6feb;
        --success: #3fb950;
        --danger: #f85149;
      }
      
      body {
        margin: 0;
        padding: 0;
        background-color: var(--bg-color);
        color: var(--text-color);
        font-family: 'Roboto', sans-serif;
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        min-height: 100vh;
        overflow: hidden;
        text-align: center;
        position: relative;
      }

      /* Lightning Effect */
      body::before {
        content: "";
        position: absolute;
        top: 0; left: 0; width: 100%; height: 100%;
        background-color: var(--lightning);
        opacity: 0;
        z-index: -1;
        animation: lightning 5s infinite;
        pointer-events: none;
      }

      @keyframes lightning {
        0% { opacity: 0; }
        2% { opacity: 0.8; }
        4% { opacity: 0; }
        6% { opacity: 0.3; }
        8% { opacity: 0; }
        100% { opacity: 0; }
      }

      .container {
        padding: 2.5rem;
        border: 2px solid #30363d;
        border-radius: 20px;
        background: rgba(22, 27, 34, 0.9);
        box-shadow: 0 15px 50px rgba(0, 0, 0, 0.7);
        max-width: 650px;
        width: 90%;
        border-top: 5px solid var(--accent-glow);
      }

      h1 {
        font-family: 'Creepster', cursive;
        font-size: 4rem;
        color: var(--accent-glow);
        text-shadow: 0 0 10px var(--accent-glow);
        margin: 0;
        letter-spacing: 4px;
      }

      h2 {
        font-size: 1.5rem;
        font-weight: 300;
        margin: 10px 0 30px;
        color: #8b949e;
        text-transform: uppercase;
      }

      .status-card {
        background: #161b22;
        padding: 20px;
        border-radius: 12px;
        border: 1px solid #30363d;
        text-align: left;
        margin-top: 20px;
      }

      .status-item {
        margin-bottom: 15px;
        display: flex;
        justify-content: space-between;
        border-bottom: 1px solid #30363d;
        padding-bottom: 8px;
      }

      .label {
        font-family: monospace;
        color: #8b949e;
        font-size: 1rem;
      }

      .value {
        font-weight: bold;
        color: var(--text-color);
      }

      .badge {
        font-weight: bold;
        padding: 4px 12px;
        border-radius: 15px;
        font-size: 0.85rem;
        text-transform: uppercase;
      }

      .badge-connected { background: rgba(63, 185, 80, 0.1); color: var(--success); border: 1px solid var(--success); }
      .badge-disconnected { background: rgba(248, 81, 73, 0.1); color: var(--danger); border: 1px solid var(--danger); }

  body
    div.container
      h1 IT'S ALIVE!
      h2 TyMCO Legacy BackEnd Server
      
      div.status-card
        div.status-item
          span.label INFRASTRUCTURE
          span.value MongoDB Atlas (Legacy MERN)
          
        div.status-item
          span.label DB USER
          span.value #{db_user}
          
        div.status-item
          span.label DB NAME
          span.value #{db_name}
          
        div.status-item
          span.label STATUS
          if db_status === 'Connected'
            span.badge.badge-connected ALIVE
          else
            span.badge.badge-disconnected DEAD
            
        div.status-item
          span.label UPTIME
          span.value #{uptime} s
          
        div.status-item
          span.label VERSION
          span.value v1.0.1 (Stable)
      
      p(style="margin-top: 2rem; color: #8b949e; font-style: italic;") 🧬 Monitoreo soberano en tiempo real para TyMCO.
